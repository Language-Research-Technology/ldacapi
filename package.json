{
  "name": "ldacapi",
  "version": "1.0.0",
  "description": "Implementation of Arocapi for Language Data Commons - REST API using TypeScript, Fastify, and Prisma",
  "main": "src/index.ts",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "dev": "node --env-file=.env --watch src/index.ts",
    "generate": "npx prisma generate",
    "migrate": "npx prisma migrate dev",
    "syncdb": "ln -sfn ../node_modules/arocapi/prisma/models prisma/arocapi && npx prisma generate && npx prisma db push",
    "index": "node scripts/indexOCFL.mjs",
    "db:console:bash": "docker compose exec db bash",
    "db:console": "docker compose exec db psql -U root -d catalog"
  },
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@biomejs/biome": "^2.2.5",
    "@fastify/bearer-auth": "^10.1.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/routes": "^6.0.2",
    "@fastify/sensible": "^6.0.4",
    "@ocfl/ocfl-fs": "^0.3.0",
    "@opensearch-project/opensearch": "^3.5.1",
    "@prisma/client": "^6.18.0",
    "arocapi": "^2.0.3",
    "fastify": "^5.6.1",
    "fastify-cli": "^7.4.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "prisma": "^6.18.0",
    "ro-crate": "^3.6.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "prisma-json-types-generator": "^3.6.2",
    "vitest": "^4.0.15"
  }
}
