{
  "name": "ldacapi",
  "version": "1.0.0",
  "description": "Implementation of Arocapi for Language Data Commons - REST API using TypeScript, Fastify, and Prisma",
  "main": "src/index.ts",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "NODE_ENV=test prisma migrate reset -f && vitest run",
    "dev": "node --env-file=.env --watch src/index.ts",
    "db:reset": "prisma migrate reset -f && npx prisma generate && npx prisma db push",
    "migrate": "npx prisma migrate dev",
    "db:sync": "ln -sfn ../node_modules/arocapi/prisma/models prisma/arocapi && npx prisma generate && npx prisma db push",
    "index": "node scripts/indexOCFL.mjs",
    "db:console:bash": "docker compose exec db bash",
    "db:console": "docker compose exec db psql -U root -d catalog"
  },
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@biomejs/biome": "^2.4.9",
    "@fastify/bearer-auth": "^10.1.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/routes": "^6.0.2",
    "@fastify/sensible": "^6.0.4",
    "@ocfl/ocfl-fs": "^0.3.0",
    "@opensearch-project/opensearch": "^3.5.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.5.0",
    "arocapi": "3.0.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "hash-wasm": "^4.12.0",
    "p-limit": "^7.3.0",
    "prisma": "^7.5.0",
    "ro-crate": "^3.7.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "pino-pretty": "^13.1.3",
    "prisma-json-types-generator": "^4.1.1",
    "vitest": "^4.1.1"
  }
}
